# Seekr Authentication
# Set SEEKR_USERNAME and either SEEKR_PASSWORD_HASH or SEEKR_PASSWORD.
# If neither password setting is provided, Seekr generates a random bootstrap
# password at startup and prints it to the server logs.
#
# Preferred format:
# SEEKR_PASSWORD_HASH=pbkdf2_sha256$600000$<salt-base64>$<hash-base64>
#
# Optional session tuning:
# SEEKR_SESSION_TTL_HOURS=24
# SEEKR_SESSION_IDLE_MINUTES=30
# SEEKR_LOGIN_MAX_FAILURES=5
# SEEKR_LOGIN_WINDOW_MINUTES=15
# SEEKR_LOGIN_LOCKOUT_MINUTES=15
# SEEKR_SECURE_COOKIES=false

SEEKR_USERNAME=admin
# SEEKR_PASSWORD_HASH=
# SEEKR_PASSWORD=
